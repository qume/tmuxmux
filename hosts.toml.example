# tmuxmux host list.
# Copy to hosts.toml (same directory as the binary, the cwd, or
# ~/.config/tmuxmux/hosts.toml) and edit.

# The local machine.
[[hosts]]
name = "localhost"
local = true

# Simple form — anything ssh can resolve (alias from ~/.ssh/config, FQDN, IP).
# Key-based auth is assumed (connections use BatchMode).
[[hosts]]
name = "buildbox"
# username = "alice"   # optional

# Custom-command form — the full shell invocation that opens the login
# session; `tmux -u attach -t <session>` is appended to it. Use this for
# jump hosts, sshpass, cloudflared tunnels, etc. Include `-tt` so the
# remote tmux gets a pty. `name` is the sidebar label.
[[hosts]]
name = "tunnelled-app"
command = "sshpass -p secret ssh -tt -o ProxyCommand='cloudflared access ssh --hostname app-ssh.example.com' dev@app-ssh.example.com"

# Per-host environment overrides for the spawned connection (empty string
# removes the variable). A top-level [env] table applies to every host.
# [[hosts]]
# name = "fussy-host"
# env = { TERM = "xterm-256color", NO_COLOR = "" }

# [env]
# TERM = "xterm-256color"
